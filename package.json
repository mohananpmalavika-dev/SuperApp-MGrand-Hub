{
  "name": "superapp-mgrand-hub",
  "version": "1.0.0",
  "description": "Modern microservices-based super app platform",
  "main": "index.js",
  "scripts": {
    "install:all": "node scripts/install-all.js",
    "dev:all": "node scripts/dev-all.js",
    "start:all": "node scripts/start-all.js",
    "test": "node scripts/test-all.js",
    "test:integration": "node scripts/test-integration.js",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "deploy:gcloud": "node scripts/deploy-gcloud.js",
    "deploy:aws": "node scripts/deploy-aws.js"
  },
  "keywords": [
    "microservices",
    "super-app",
    "nodejs",
    "mongodb",
    "redis",
    "ecommerce"
  ],
  "author": "MGrand Hub Team",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
