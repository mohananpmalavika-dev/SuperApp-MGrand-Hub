# Resume Service Configuration

# Server
PORT=3006
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/superapp-resume

# JWT
JWT_SECRET=your-resume-service-secret-key-change-in-production
JWT_EXPIRY=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# File Storage
UPLOAD_DIR=./uploads/resumes
MAX_FILE_SIZE=10485760

# PDF Generation
PDF_QUALITY=high
PDF_DPI=300

# Service Info
SERVICE_NAME=resume-service
SERVICE_VERSION=1.0.0
