# Messaging Service Configuration

# Server
PORT=3007
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/superapp-messaging

# JWT
JWT_SECRET=your-messaging-service-secret-key-change-in-production
JWT_EXPIRY=7d

# Redis (for real-time features)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# File Storage (S3 or local)
STORAGE_TYPE=local
UPLOAD_DIR=./uploads/messaging
MAX_FILE_SIZE=52428800
S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# WebRTC Configuration
WEBRTC_STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
WEBRTC_TURN_URLS=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_CREDENTIAL=

# Encryption
ENCRYPTION_ALGORITHM=aes-256-gcm
MESSAGE_ENCRYPTION_ENABLED=true

# AI Features
AI_ENABLED=true
OPENAI_API_KEY=
GEMINI_API_KEY=

# Translation
TRANSLATION_ENABLED=true
DEFAULT_LANGUAGE=en

# Message Limits
MAX_MESSAGE_LENGTH=10000
MAX_MEDIA_FILES_PER_MESSAGE=10
MESSAGE_EDIT_TIME_LIMIT=300000

# Group Chat
MAX_GROUP_PARTICIPANTS=500
MAX_CHATROOM_PARTICIPANTS=10000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Service Info
SERVICE_NAME=messaging-service
SERVICE_VERSION=1.0.0
