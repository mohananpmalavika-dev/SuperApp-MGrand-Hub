# Service Configuration
NODE_ENV=development
PORT=3005
SERVICE_NAME=tutor-service

# Database
MONGO_URI=mongodb://localhost:27017/mgrand-hub
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRE=7d

# Service URLs (for communication)
AUTH_SERVICE_URL=http://auth-service:3001
USER_SERVICE_URL=http://user-service:3002
NOTIFICATION_SERVICE_URL=http://notification-service:3012

# External APIs (Optional - for enhanced features)
OPENAI_API_KEY=your-openai-key-optional
GOOGLE_AI_KEY=your-google-ai-key-optional

# Feature Flags
ENABLE_AI_TUTOR=true
ENABLE_GAMIFICATION=true
ENABLE_COLLABORATIVE_LEARNING=true
ENABLE_VIDEO_LESSONS=true

# Gamification Settings
POINTS_PER_LESSON=10
POINTS_PER_QUIZ=20
POINTS_PER_ACHIEVEMENT=50
STREAK_BONUS_MULTIPLIER=1.5

# Session Settings
SESSION_TIMEOUT_MINUTES=60
MAX_CONCURRENT_SESSIONS=3
