# Service Config
NODE_ENV=development
PORT=3002
SERVICE_NAME=user-service

# Database
MONGO_URI=mongodb://localhost:27017/mgrand-hub

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-jwt-secret

# Service URLs
AUTH_SERVICE_URL=http://localhost:3001

# CORS
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
